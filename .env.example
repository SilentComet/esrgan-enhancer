# ESRGAN Enhancement Platform - Environment Configuration
# Authored by: DevOps Engineering Team
# Date: April 2026

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=2
RELOAD=false

# Security
SECRET_KEY=change-this-to-a-secure-random-key-in-production
API_KEY_HEADER=X-API-Key
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# CORS
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=500

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
UPLOAD_TEMP_DIR=/tmp/uploads

# ============================================================================
# ML MODEL CONFIGURATION
# ============================================================================

# Device
ENABLE_CUDA=true
DEVICE=auto
MODEL_PRECISION=fp32

# Model Paths
MODEL_WEIGHTS_PATH=./ml/weights/ESRGAN_x4.pth
MODEL_ONNX_PATH=./ml/weights/ESRGAN_x4.onnx

# Inference
SCALE_FACTOR=4
TILE_SIZE=512
TILE_OVERLAP=32
BATCH_SIZE=1

# ============================================================================
# REDIS & CELERY CONFIGURATION
# ============================================================================

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite (Development)
DATABASE_URL=sqlite+aiosqlite:///./esrgan.db

# PostgreSQL (Production - uncomment and configure)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/esrgan

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/esrgan.log

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

VITE_API_URL=http://localhost:8000
VITE_MAX_FILE_SIZE=10485760
VITE_ENABLE_ANALYTICS=false
